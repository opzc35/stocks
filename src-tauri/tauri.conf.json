{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stocks Trading Client",
  "version": "0.1.0",
  "identifier": "com.stocks.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "app", "dmg", "deb", "appimage"]
  },
  "app": {
    "windows": [
      {
        "title": "Stocks Trading Client",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
